# =============================================================================
# LexAI Legal Intake Agent — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# Required — OpenAI API key for Analyzer LLM + Speaker LLM + vision analysis
OPENAI_API_KEY=sk-...

# Optional — Deepgram API key for speech-to-text (voice mode)
# Leave blank to disable STT. Voice mode degrades to chat-only without this.
DEEPGRAM_API_KEY=

# Optional — ElevenLabs API key for text-to-speech (voice mode)
# Leave blank to disable TTS. Voice mode degrades to text-only without this.
ELEVENLABS_API_KEY=

# Optional — ElevenLabs voice ID (default: Rachel)
# Browse voices at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Optional — Server port (default: 3000)
PORT=3000
