{
  "name": "lexai-legal-intake-agent",
  "version": "1.0.0",
  "description": "LexAI — 6-phase criminal/civil legal intake agent with voice support and Litmetrics dashboard",
  "main": "dist/src/pipeline.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/pipeline.ts",
    "build": "tsc",
    "start": "node dist/src/pipeline.js",
    "test": "ts-node src/test.ts",
    "test:unit": "ts-node src/test.ts --unit",
    "test:e2e": "ts-node src/test.ts --e2e"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@libsql/client": "^0.4.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.3",
    "form-data": "^4.0.0",
    "langsmith": "^0.5.16",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.33.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
